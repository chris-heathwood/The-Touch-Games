default_platform(:ios)

PROJECT_ROOT = File.expand_path("..", __dir__)
BUILD_PATH   = ENV["UNITY_BUILD_PATH"] || File.join(PROJECT_ROOT, "Build")
XCODEPROJ    = File.join(BUILD_PATH, "Unity-iPhone.xcodeproj")

platform :ios do

  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"] || ".asc_key.p8"
    )

    get_certificates(api_key: api_key)
    get_provisioning_profile(
      api_key:        api_key,
      app_identifier: "com.thetouchgames.app"
    )

    build_app(
      project:          XCODEPROJ,
      scheme:           "Unity-iPhone",
      export_method:    "app-store",
      output_directory: "#{BUILD_PATH}/Archive"
    )

    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true
    )

    puts "Done! Build uploaded to TestFlight."
  end

  desc "Submit current build to App Store review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"] || ".asc_key.p8"
    )

    deliver(
      api_key:             api_key,
      submit_for_review:   true,
      automatic_release:   false,
      force:               true
    )
  end

end
